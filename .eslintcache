ckToInput' and 'onDone'. Either include them or remove the dependency array. If 'onBackToInput' changes too often, find the parent component that defines it and wrap that definition in useCallback.","ArrayExpression",["402"],["403"],["404"],"Error: Cannot call impure function during render\n\n`Date.now` is an impure function. Calling an impure function can produce unstable results that update unpredictably when the component happens to re-render. (https://react.dev/reference/rules/components-and-hooks-must-be-pure#components-and-hooks-must-be-idempotent).\n\n  719 |     // car la valeur n'influence pas l'arbre (pas de condition de rendu).\n  720 |     // eslint-disable-next-line react-hooks/purity\n> 721 |     const diff = Date.now() - ms;\n      |                  ^^^^^^^^^^ Cannot call impure function\n  722 |     const day = 86400000;\n  723 |     if (diff < day) return \"aujourd'hui\";\n  724 |     if (diff < 2 * day) return 'hier';",["405"],"React Hook useEffect has a missing dependency: 'screen'. Either include it or remove the dependency array.",["406"],["407"],"'e' is defined but never used.","'useState' is defined but never used. Allowed unused vars must match /^[A-Z_]/u.",["408"],"'Icon' is defined but never used.",["409"],"react-refresh/only-export-components","Fast refresh only works when a file only exports components. Use a new file to share constants or functions between components.","namedExport","react-hooks/set-state-in-effect","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n   96 |\n   97 |     let cancelled = false;\n>  98 |     setLoading(true);\n      |     ^^^^^^^^^^ Avoid calling setState() directly within an effect\n   99 |\n  100 |     (async () => {\n  101 |       try {",["410"],"React Hook useEffect has missing dependencies: 'currentIdx', 'isPlaying', 'onNext', and 'playlist'. Either include them or remove the dependency array. If 'onNext' changes too often, find the parent component that defines it and wrap that definition in useCallback.",["411"],["412"],["413","414"],["415"],"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n  32 |   useEffect(() => {\n  33 |     if (renameOpen) {\n> 34 |       setRenameValue(version.name || '');\n     |       ^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  35 |       setTimeout(() => inputRef.current?.select(), 50);\n  36 |     }\n  37 |   }, [renameOpen, version.name]);","no-control-regex","Unexpected control character(s) in regular expression: \\x00.",["416"],"React Hook useEffect has a missing dependency: 'initialProjectId'. Either include it or remove the dependency array.",["417"],["418"],"React Hook useEffect has missing dependencies: 'autoSelectTrackTitle' and 'onAutoSelectConsumed'. Either include them or remove the dependency array. If 'onAutoSelectConsumed' changes too often, find the parent component that defines it and wrap that definition in useCallback.",["419"],["420"],{"messageId":"421","data":"422","fix":"423","desc":"424"},{"messageId":"421","data":"425","fix":"426","desc":"427"},{"messageId":"421","data":"428","fix":"429","desc":"430"},{"messageId":"431","data":"432","fix":"433","desc":"434"},{"messageId":"435","fix":"436","desc":"437"},{"messageId":"438","fix":"439","desc":"440"},{"messageId":"421","data":"441","fix":"442","desc":"443"},{"messageId":"421","data":"444","fix":"445","desc":"446"},{"messageId":"421","data":"447","fix":"448","desc":"449"},{"messageId":"421","data":"450","fix":"451","desc":"452"},{"messageId":"421","data":"453","fix":"454","desc":"455"},{"messageId":"431","data":"456","fix":"457","desc":"434"},{"desc":"458","fix":"459"},{"messageId":"431","data":"460","fix":"461","desc":"434"},{"messageId":"431","data":"462","fix":"463","desc":"434"},{"kind":"464","justification":"465"},{"desc":"466","fix":"467"},{"kind":"464","justification":"465"},{"messageId":"421","data":"468","fix":"469","desc":"470"},{"messageId":"421","data":"471","fix":"472","desc":"473"},{"messageId":"431","data":"474","fix":"475","desc":"434"},{"desc":"476","fix":"477"},{"messageId":"431","data":"478","fix":"479","desc":"434"},{"messageId":"435","fix":"480","desc":"437"},{"messageId":"438","fix":"481","desc":"440"},{"messageId":"421","data":"482","fix":"483","desc":"455"},{"kind":"464","justification":"484"},{"desc":"485","fix":"486"},{"kind":"464","justification":"465"},{"desc":"487","fix":"488"},{"messageId":"421","data":"489","fix":"490","desc":"446"},"removeVar",{"varName":"491"},{"range":"492","text":"465"},"Remove unused variable 'trackId'.",{"varName":"493"},{"range":"494","text":"465"},"Remove unused variable 'fromIdx'.",{"varName":"495"},{"range":"496","text":"465"},"Remove unused variable 'toIdx'.","suggestComment",{"type":"497"},{"range":"498","text":"499"},"Add comment inside empty block statement.","removeEscape",{"range":"500","text":"465"},"Remove the `\\`. This maintains the current functionality.","escapeBackslash",{"range":"501","text":"502"},"Replace the `\\` with `\\\\` to include the actual backslash character.",{"varName":"503"},{"range":"504","text":"465"},"Remove unused variable '_'.",{"varName":"505"},{"range":"506","text":"465"},"Remove unused variable 'i'.",{"varName":"507"},{"range":"508","text":"465"},"Remove unused variable 'backdrop'.",{"varName":"509"},{"range":"510","text":"465"},"Remove unused variable 'panel'.",{"varName":"511"},{"range":"512","text":"465"},"Remove unused variable 'open'.",{"type":"497"},{"range":"513","text":"499"},"Update the dependencies array to be: [config, onBackToInput, onDone]",{"range":"514","text":"515"},{"type":"497"},{"range":"516","text":"499"},{"type":"497"},{"range":"517","text":"499"},"directive","","Update the dependencies array to be: [screen, user]",{"range":"518","text":"519"},{"varName":"520"},{"range":"521","text":"465"},"Remove unused variable 'useState'.",{"varName":"522"},{"range":"523","text":"465"},"Remove unused variable 'Icon'.",{"type":"497"},{"range":"524","text":"499"},"Update the dependencies array to be: [storagePath, resetKey, isPlaying, playlist, currentIdx, onNext]",{"range":"525","text":"526"},{"type":"497"},{"range":"527","text":"499"},{"range":"528","text":"465"},{"range":"529","text":"502"},{"varName":"511"},{"range":"530","text":"465"},"Latin-1 inclut la plage de contrôle, c'est volontaire ici.","Update the dependencies array to be: [initialProjectId]",{"range":"531","text":"532"},"Update the dependencies array to be: [autoSelectTrackTitle, onAutoSelectConsumed]",{"range":"533","text":"534"},{"varName":"505"},{"range":"535","text":"465"},"trackId",[14527,14535],"fromIdx",[14534,14543],"toIdx",[14543,14550],"block",[14975,14975]," /* empty */ ",[6546,6547],[6546,6546],"\\","_",[13033,13035],"i",[13034,13037],"backdrop",[28472,28506],"panel",[28509,28537],"open",[32660,32666],[3902,3902],[8449,8457],"[config, onBackToInput, onDone]",[83231,83231],[83352,83352],[79418,79424],"[screen, user]","useState",[0,33],"Icon",[923,929],[3817,3817],[5148,5171],"[storagePath, resetKey, isPlaying, playlist, currentIdx, onNext]",[5460,5460],[4457,4458],[4457,4457],[27660,27666],[9730,9732],"[initialProjectId]",[963,965],"[autoSelectTrackTitle, onAutoSelectConsumed]",[4053,4056]]